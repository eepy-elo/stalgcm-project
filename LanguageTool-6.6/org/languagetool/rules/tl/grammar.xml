<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="../../../../../../../../../languagetool-core/src/main/resources/org/languagetool/rules/print.xsl" ?>
<?xml-stylesheet type="text/css" href="../../../../../../../../../languagetool-core/src/main/resources/org/languagetool/rules/rules.css" title="Easy editing stylesheet" ?>
<!-- Tagalog Grammar and Typo Rules for LanguageTool -->

<rules lang="tl" xsi:noNamespaceSchemaLocation="../../../../../../../../../languagetool-core/src/main/resources/org/languagetool/rules/rules.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xs="http://www.w3.org/2001/XMLSchema">
    
	<!-- RULE 1 -->
	<category id="ADJ_REDUPLICATION" name="Adjacent Reduplications">
		<rule id="XU-XO" name="Xu-Xo (XuXo)">
			<antipattern case_sensitive="no">
				<token>paru</token>
				<token>-</token>
				<token regexp="yes">gamo|salo|balo|halo</token>
			</antipattern>

			<antipattern case_sensitive="no">
				<token>gamu</token>
				<token>-</token>
				<token regexp="yes">paro|salo|balo|halo</token>
			</antipattern>

			<antipattern case_sensitive="no">
				<token>salu</token>
				<token>-</token>
				<token regexp="yes">paro|gamo|balo|halo</token>
			</antipattern>

			<antipattern case_sensitive="no">
				<token>balu</token>
				<token>-</token>
				<token regexp="yes">paro|gamo|salo|halo</token>
			</antipattern>

			<antipattern case_sensitive="no">
				<token>halu</token>
				<token>-</token>
				<token regexp="yes">paro|gamo|salo|balo</token>
			</antipattern>

			<pattern case_sensitive="no">
				<marker>
					<token regexp="yes">paru|gamu|salu|balu|halu</token>
					<token>-</token>
					<token regexp="yes">paro|gamo|salo|balo|halo</token>
				</marker>
			</pattern>
			<message>Do you mean <suggestion><match no="1"/><match no="3"/></suggestion>?</message>
			<short>Adjacent Reduplication</short>

			<example correction="paruparo" type="incorrect">
				Tignan mo ang mga <marker>paru-paro</marker>.</example>
			<example type="correct">Tignan mo ang mga paruparo.</example>
			<example correction="gamugamo" type="incorrect">
				Madalas makita ang <marker>gamu-gamo</marker> tuwing tag-ulan.</example>
			<example type="correct">Madalas makita ang gamugamo tuwing tag-ulan.</example>
			<example correction="salusalo" type="incorrect">
				Magkakaroon tayo ng munting <marker>salu-salo</marker> bukas.</example>
			<example type="correct">Magkakaroon tayo ng munting salusalo bukas.</example>
		</rule>
	</category>

	<!-- RULE 2 -->
	<category id="SPANISH" name="Filipino-Spanish Words">
		<rule id="DE_PREFIX_HYPHEN" name="De Prefix">
			<pattern case_sensitive="no">
				<marker>
                    <token regexp="yes">(de)(bote|lata|kolor|mano|bola)</token>
                </marker>
			</pattern>
			<message>
				Do you mean <suggestion><match no="1" regexp_match="(de)(\w+)" regexp_replace="$1-$2"/></suggestion>?
			</message>
			<short>Filipino-Spanish Words</short>

			<example correction="de-bote" type="incorrect">
				<marker>Debote</marker> ang binili niya.</example>
			<example type="correct">De-bote ang binili niya.</example>
		</rule>
	</category>

	<!-- RULE 3 -->
	<category id="APOSTROPHE" name="Possesive Pronoun Contractions">
		<rule id="APOSTROPHE_PRONOUN" name="Apostrophe Pronoun">
			<antipattern case_sensitive="no">
				<token regexp="yes">[a-z]*ng</token>
				<token>satin</token>
			</antipattern>

			<antipattern case_sensitive="no">
				<token>satin</token>
				<token>na</token>
				<token regexp="yes">tela|damit|gown|bestida|blouse|palda|ribbon|laso|unan|kumot|kurtina</token>
			</antipattern>

			<pattern case_sensitive="no">
				<token regexp="yes">(?i)(sa)(yo(?:ng)?|kin(?:g)?|tin(?:g)?|min(?:g)?)</token>
			</pattern>
			<message>
				Do you mean <suggestion><match no="1" regexp_match="(?i)(sa)(yo(?:ng)?|kin(?:g)?|tin(?:g)?|min(?:g)?)" regexp_replace="$1 '$2"/></suggestion>?
			</message>
			<short>Possesive Pronoun Contraction</short>

			<example correction="sa 'yo" type="incorrect">
				Para <marker>sayo</marker> ang laban na ito.
			</example>
			<example type="correct">Para sa 'yo ang laban na ito.</example>
		</rule>
	</category>

</rules>